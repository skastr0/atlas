{
  "name": "@skastr0/atlas-opencode-plugin",
  "version": "0.1.2",
  "description": "OpenCode plugin for keeping Atlas indexes refreshed during agent sessions",
  "type": "module",
  "author": "Guilherme Castro <skastr052@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/skastr0/atlas#readme",
  "bugs": {
    "url": "https://github.com/skastr0/atlas/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skastr0/atlas.git",
    "directory": "apps/opencode-plugin"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target bun --format esm --external @opencode-ai/plugin --external effect",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "validate": "bun run typecheck && bun test",
    "verify": "bun run typecheck && bun run test && bun run build && bun run pack:dry-run",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "effect": "3.21.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.3.17"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.3.17",
    "@opencode-ai/sdk": "1.3.17",
    "@types/bun": "1.3.13",
    "typescript": "5.9.3"
  },
  "engines": {
    "opencode": ">=1.3.17"
  },
  "keywords": [
    "atlas",
    "opencode",
    "opencode-plugin",
    "knowledge-base",
    "indexing"
  ]
}
